# ════════════════════════════════════════════════════════════════
#  DeepDive Interviewer — Server Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
# Port the Express server listens on (default: 3001)
PORT=3001

# Set to "production" when deploying
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's REST/realtime URL
# e.g. https://xyzcompany.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key — has full DB access, bypasses RLS.
# ⚠️  Keep this SECRET — server-side only, never in the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API.
# Add your production frontend URL here before deploying.
ALLOWED_ORIGINS=http://localhost:5173

# ── File Upload ───────────────────────────────────────────────────
# Maximum PDF file size accepted (in MB). Default: 10
MAX_FILE_SIZE_MB=10
