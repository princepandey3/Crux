# ════════════════════════════════════════════════════════════════
#  DeepDive Interviewer — Server Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Providers ─────────────────────────────────────────────────────
# Choose ONE option for each.

# Option A: OpenAI  (embeddings: text-embedding-3-small 1536 dims, LLM: gpt-4o)
# EMBEDDING_PROVIDER=openai
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Option B: Google Gemini  (embeddings: text-embedding-004 768 dims, LLM: gemini-2.5-flash)
# ⚠️  If using Gemini embeddings you MUST change vector(1536) → vector(768) in
#     schema.sql BEFORE running it for the first time.
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini
# FIX: the correct env var name is GOOGLE_API_KEY (not GEMINI_API_KEY)
GOOGLE_API_KEY=AIza...

# ── RAG tuning ────────────────────────────────────────────────────
RAG_MATCH_COUNT=6
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
